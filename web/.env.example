# PocketBase URL for the browser API (omit when the SPA is served from the same origin as PocketBase, e.g. Docker image).
# For local dev with Vite on :5173 and PocketBase on :8090, leave unset — Vite proxies /api to PocketBase.
# PUBLIC_POCKETBASE_URL=http://127.0.0.1:8090

# Web Push: must match the relay’s VAPID public key (never put the private key in the frontend).
# Generate with e.g. `npx --yes web-push generate-vapid-keys` and use the same public value here and in letztes-bier-push.
# PUBLIC_VAPID_PUBLIC_KEY=
