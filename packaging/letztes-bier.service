[Unit]
Description=Letztes Bier (PocketBase + static SPA)
After=networking.service
Wants=networking.service

[Service]
EnvironmentFile=/etc/default/letztes-bier
Type=simple
ExecStart=/pb/pocketbase serve ${PB_DOMAIN} --dir=/pb/pb_data --publicDir=/pb/pb_public --migrationsDir=/pb/pb_migrations --hooksDir=/pb/pb_hooks
StandardOutput=journal+console
StandardError=journal+console
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
